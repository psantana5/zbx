{"version": 2, "width": 72, "height": 35, "timestamp": 1772782790, "env": {"SHELL": "/usr/bin/zsh", "TERM": "xterm-256color"}}
[0.01373, "o", "\u001b[H\u001b[2J\u001b[3J"]
[0.015283, "o", "\r\n\u001b[1;36mв”Ђв”Ђ zbxctl: Zabbix configuration as code в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\u001b[0m\r\n"]
[1.821022, "o", "\r\n\u001b[1;36m1. Version + connectivity check\u001b[0m\r\n"]
[2.424061, "o", "\u001b[1;32m$ zbx --version\u001b[0m\r\n"]
[3.317342, "o", "zbx 0.4.0\r\n"]
[4.404728, "o", "\u001b[1;32m$ zbx status\u001b[0m\r\n"]
[5.554517, "o", "\r\n"]
[5.558656, "o", "\u001b[2m  \u001b[0m\u001b[2mzbx version     \u001b[0m\u001b[2m  \u001b[0m\u001b[1m  \u001b[0m\u001b[1m0.4.0                  \u001b[0m\u001b[1m  \u001b[0m\r\n\u001b[2m  \u001b[0m\u001b[2mZabbix server   \u001b[0m\u001b[2m  \u001b[0m\u001b[1m  \u001b[0m\u001b[1mhttp://localhost/zabbix\u001b[0m\u001b[1m  \u001b[0m\r\n\u001b[2m  \u001b[0m\u001b[2mAPI version     \u001b[0m\u001b[2m  \u001b[0m\u001b[1m  \u001b[0m\u001b[1m7.4.7                  \u001b[0m\u001b[1m  \u001b[0m\r\n\u001b[2m  \u001b[0m\u001b[2mAuthenticated as\u001b[0m\u001b[2m  \u001b[0m\u001b[1m  \u001b[0m\u001b[1mAdmin                  \u001b[0m\u001b[1m  \u001b[0m\r\n\u001b[2m  \u001b[0m\u001b[2mTemplates       \u001b[0m\u001b[2m  \u001b[0m\u001b[1m  \u001b[0m\u001b[1m364                    \u001b[0m\u001b[1m  \u001b[0m\r\n\u001b[2m  \u001b[0m\u001b[2mHosts           \u001b[0m\u001b[2m  \u001b[0m\u001b[1m  \u001b[0m\u001b[1m3 total  (3 enabled)   \u001b[0m\u001b[1m  \u001b[0m\r\n"]
[5.558769, "o", "\r\n"]
[5.562773, "o", "\u001b[32mвњ“\u001b[0m  Connected and authenticated.\r\n\r\n"]
[7.881971, "o", "\r\n\u001b[1;36m2. Validate config before deploying\u001b[0m\r\n"]
[8.485424, "o", "\u001b[1;32m$ zbx validate configs/checks/postgresql/\u001b[0m\r\n"]
[9.402633, "o", "\u001b[32mok Validated \u001b[0m\u001b[1;32m1\u001b[0m\u001b[32m \u001b[0m\u001b[1;32mtemplate\u001b[0m\u001b[1;32m(\u001b[0m\u001b[32ms\u001b[0m\u001b[1;32m)\u001b[0m\u001b[32m вЂ” no schema errors.\u001b[0m\r\n"]
[11.705856, "o", "\r\n\u001b[1;36m3. Plan вЂ” what would change? (no writes)\u001b[0m\r\n"]
[12.308845, "o", "\u001b[1;32m$ zbx plan configs/checks/postgresql/\u001b[0m\r\n"]
[13.490215, "o", "\u001b[32mok No changes. Infrastructure is up-to-date.\u001b[0m\r\n"]
[15.826764, "o", "\r\n\u001b[1;36m4. Apply вЂ” deploy the template\u001b[0m\r\n"]
[16.430222, "o", "\u001b[1;32m$ zbx apply configs/checks/postgresql/\u001b[0m\r\n"]
[17.572675, "o", "\u001b[32mok No changes. Infrastructure is up-to-date.\u001b[0m\r\n"]
[19.899803, "o", "\r\n\u001b[1;36m5. Apply is idempotent вЂ” running again makes no changes\u001b[0m\r\n"]
[20.503047, "o", "\u001b[1;32m$ zbx apply configs/checks/postgresql/\u001b[0m\r\n"]
[21.624143, "o", "\u001b[32mok No changes. Infrastructure is up-to-date.\u001b[0m\r\n"]
[23.940198, "o", "\r\n\u001b[1;36m6. Diff вЂ” compare YAML to live Zabbix\u001b[0m\r\n"]
[24.543562, "o", "\u001b[1;32m$ zbx diff configs/checks/postgresql/\u001b[0m\r\n"]
[25.692501, "o", "\u001b[32mok No changes. Infrastructure is up-to-date.\u001b[0m\r\n"]
[28.024802, "o", "\r\n\u001b[1;36m7. Export an existing template to YAML\u001b[0m\r\n"]
[28.627993, "o", "\u001b[1;32m$ zbx export 'Windows by Zabbix agent'\u001b[0m\r\n"]
[30.023247, "o", "template: Windows by Zabbix agent\r\ndescription: \"This is an official Windows template. It requires Zabbix agent 7.4 or\\\r\n  \\ newer.\\r\\n\\r\\nYou can discuss this template or leave feedback on our forum https://www.zabbix.com/forum/zabbix-suggestions-and-feedback/387224-discussion-thread-for-official-zabbix-template-for-windows\\r\\\r\n  \\n\\r\\nGenerated by official Zabbix template tool \\\"Templator\\\"\"\r\ngroups:\r\n- Templates\r\nitems:\r\n- name: Host name of Zabbix agent running\r\n  key: agent.hostname\r\n  interval: 1h\r\n  value_type: char\r\n  history: 31d\r\n  trends: '0'\r\n  tags:\r\n  - tag: component\r\n    value: system\r\n- name: Zabbix agent ping\r\n  key: agent.ping\r\n  interval: 1m\r\n  value_type: unsigned\r\n  description: The agent always returns \"1\" for this item. May be used in combination\r\n    with `nodata()` for the availability check.\r\n  history: 31d\r\n  tags:\r\n  - tag: component\r\n    value: system\r\n- name: Version of Zabbix agent running\r\n  key: agent.version\r\n  interval: 1h\r\n  value_type: char\r\n  history: 31d\r\n  trends: '0'\r\n  tags:\r\n  - tag: component\r\n    value: application\r\n- name: Cache bytes\r\n  key: perf_counter_en[\"\\Memory\\Cache Bytes\"]\r\n  interval: 1m\r\n  value_type: unsigned\r\n  units: B\r\n  description: Cache Bytes is the sum of the Memory\\\\System Cache Resident Bytes,\r\n    Memory\\\\System Driver Resident Bytes, Memory\\\\System Code Resident Bytes, and\r\n    Memory\\\\Pool Paged Resident Bytes counters. This counter displays the last observed\r\n    value only; it is not an average.\r\n  history: 31d\r\n  tags:\r\n  - tag: component\r\n    value: memory\r\n- name: Free system page table entries\r\n  key: perf_counter_en[\"\\Memory\\Free System Page Table Entries\"]\r\n  interval: 1m\r\n  value_type: unsigned\r\n  description: This indicates the number of page table entries not currently in use\r\n    by the system. If the number is less than 5,000, there may be a memory leak or\r\n    you running out of memory.\r\n  history: 31d\r\n  tags:\r\n  - tag: component\r\n    value: memory\r\n- name: Memory page faults per second\r\n  key: perf_counter_en[\"\\Memory\\Page Faults/sec\"]\r\n  interval: 1m\r\n  description: Page Faults/sec is the average number of pages faulted per second.\r\n    It is measured in number of pages faulted per second because only one page is\r\n    faulted in each fault operation, hence this is also equal to the number of page\r\n    fault operations. This counter includes both hard faults (those that require disk\r\n    access) and soft faults (where the faulted page is found elsewhere in physical\r\n    memory.) Most processors can handle large numbers of soft faults without significant\r\n    consequence. However, hard faults, which require disk access, can cause significant\r\n    delays.\r\n  history: 31d\r\n  tags:\r\n  - tag: component\r\n    value: memory\r\n- name: Memory pages per second\r\n  key: perf_counter_en[\"\\Memory\\Pages/sec\"]\r\n  interval: 1m\r\n  description: \"This measures the rate at which pages are read from or written to\\\r\n    \\ disk to resolve hard page faults.\\r\\nIf the value is greater than 1,000, as\\\r\n    \\ a result of excessive paging, there may be a memory leak.\"\r\n  history: 31d\r\n  tags:\r\n  - tag: component\r\n    value: memory\r\n- name: Memory pool non-paged\r\n  key: perf_counter_en[\"\\Memory\\Pool Nonpaged Bytes\"]\r\n  interval: 1m\r\n  value_type: unsigned\r\n  units: B\r\n  description: \"This measures the size, in bytes, of the non-paged pool. This is an\\\r\n    \\ area of system memory for objects that cannot be written to disk but instead\\\r\n    \\ must remain in physical memory as long as they are allocated.\\r\\nThere is a\\\r\n    \\ possible memory leak if the value is greater than 175MB (or 100MB with the /3GB\\\r\n    \\ switch). Consequently, Event ID 2019 is recorded in the system event log.\"\r\n  history: 31d\r\n  tags:\r\n  - tag: component\r\n    value: memory\r\n- name: Used swap space in %\r\n  key: perf_counter_en[\"\\Paging file(_Total)\\% Usage\"]\r\n  interval: 1m\r\n  units: '%'\r\n  description: The used space of swap volume/file in percent.\r\n  history: 31d\r\n  tags:\r\n  - tag: component\r\n    value: memory\r\n  - tag: component\r\n    value: storage\r\n- name: CPU DPC time\r\n  key: perf_counter_en[\"\\Processor Information(_total)\\% DPC Time\"]\r\n  interval: 1m\r\n  units: '%'\r\n  description: Processor DPC time is the time that a single processor spent receiving\r\n    and servicing deferred procedure calls (DPCs). DPCs are interrupts that run at\r\n    a lower priority than standard interrupts. `% DPC Time` is a component of `% Privileged\r\n    Time` because DPCs are executed in privileged mode. If a high `% DPC Time` is\r\n    sustained, there may be a processor bottleneck or an application or hardware related\r\n    issue that can significantly diminish overall system performance.\r\n  history: 31d\r\n  tags:\r\n  - tag: component\r\n    value: cpu\r\n- name: CPU interrupt time\r\n  key: perf_counter_en[\"\\Processor Information(_total)\\% Interrupt Time\"]\r\n  interval: 1m\r\n  units: '%'\r\n  description: The processor information `% Interrupt Time` counter indicates how\r\n    much time the processor spends handling hardware interrupts during sample intervals.\r\n    It reflects the activity of devices like the system clock, mouse, disk drivers,\r\n    and network cards. A value above 20% suggests possible hardware issues.\r\n  history: 31d\r\n  tags:\r\n  - tag: component\r\n    value: cpu\r\n- name: CPU privileged time\r\n  key: perf_counter_en[\"\\Processor Information(_total)\\% Privileged Time\"]\r\n  interval: 1m\r\n  units: '%'\r\n  description: The processor information `% Privileged Time` counter shows the percent\r\n    of time that the processor is spent executing in Kernel (or Privileged) mode.\r\n    Privileged mode includes services interrupts inside Interrupt Service Routines\r\n    (ISRs), executing Deferred Procedure Calls (DPCs), Device Driver calls and other\r\n    kernel-mode functions of the Windows Operating System.\r\n  history: 31d\r\n  tags:\r\n  - tag: component\r\n    value: cpu\r\n- name: CPU user time\r\n  key: perf_counter_en[\"\\Processor Information(_total)\\% User Time\"]\r\n  interval: 1m\r\n  units: '%'\r\n  description: The processor information `% User Time` counter shows the percent of\r\n    time that the processor(s) is spent executing in User mode.\r\n  history: 31d\r\n  tags:\r\n  - tag: component\r\n    value: cpu\r\n- name: Context switches per second\r\n  key: perf_counter_en[\"\\System\\Context Switches/sec\"]\r\n  interval: 1m\r\n  description: \"Context Switches/sec is the combined rate at which all processors\\\r\n    \\ on the computer are switched from one thread to another.\\r\\nContext switches\\\r\n    \\ occur when a running thread voluntarily relinquishes the processor, is preempted\\\r\n    \\ by a higher priority ready thread, or switches between user-mode and privileged\\\r\n    \\ (kernel) mode to use an Executive or subsystem service.\\r\\nIt is the sum of\\\r\n    \\ Thread\\\\\\\\Context Switches/sec for all threads running on all processors in\\\r\n    \\ the computer and is measured in numbers of switches.\\r\\nThere are context switch\\\r\n    \\ counters on the System and Thread objects. This counter displays the difference\\\r\n    \\ between the values observed in the last two samples, divided by the duration\\\r\n    \\ of the sample interval.\"\r\n  history: 31d\r\n  tags:\r\n  - tag: component\r\n    value: cpu\r\n- name: CPU queue length\r\n  key: perf_counter_en[\"\\System\\Processor Queue Length\"]\r\n  interval: 1m\r\n  description: The Processor Queue Length shows the number of threads that are observed\r\n    as delayed in the processor Ready Queue and are waiting to be executed.\r\n  history: 31d\r\n  tags:\r\n  - tag: component\r\n    value: cpu\r\n- name: Number of threads\r\n  key: perf_counter_en[\"\\System\\Threads\"]\r\n  interval: 1m\r\n  value_type: unsigned\r\n  description: The number of threads used by all running processes.\r\n  history: 31d\r\n  tags:\r\n  - tag: component\r\n    value: os\r\n- name: Number of processes\r\n  key: proc.num[]\r\n  interval: 1m\r\n  value_type: unsigned\r\n  description: The number of processes.\r\n  history: 31d\r\n  tags:\r\n  - tag: component\r\n    value: os\r\n- name: CPU utilization\r\n  key: system.cpu.util\r\n  interval: 1m\r\n  units: '%'\r\n  description: CPU utilization expressed in %.\r\n  history: 31d\r\n  tags:\r\n  - tag: component\r\n    value: cpu\r\n- name: System name\r\n  key: system.hostname\r\n  interval: 1h\r\n  value_type: char\r\n  description: The host name of the system.\r\n  history: 31d\r\n  trends: '0'\r\n  tags:\r\n  - tag: component\r\n    value: system\r\n- name: System local time\r\n  key: system.localtime\r\n  interval: 1m\r\n  value_type: unsigned\r\n  units: unixtime\r\n  description: The local system time of the host.\r\n  history: 31d\r\n  tags:\r\n  - tag: component\r\n    value: system\r\n- name: Operating system architecture\r\n  key: system.sw.arch\r\n  interval: 1h\r\n  value_type: char\r\n  description: The architecture of the operating system.\r\n  history: 31d\r\n  trends: '0'\r\n  tags:\r\n  - tag: component\r\n    value: os\r\n- name: Operating system\r\n  key: system.sw.os\r\n  interval: 1h\r\n  value_type: char\r\n  history: 31d\r\n  trends: '0'\r\n  tags:\r\n  - tag: component\r\n    value: os\r\n- name: Free swap space\r\n  key: system.swap.free\r\n  interval: 1m\r\n  type: calculated\r\n  params: last(//system.swap.size[,total]) - last(//system.swap.size[,total]) / 100\r\n    * last(//perf_counter_en[\"\\Paging file(_Total)\\% Usage\"])\r\n  value_type: unsigned\r\n  units: B\r\n  description: The free space of the swap volume/file expressed in bytes.\r\n  history: 31d\r\n  tags:\r\n  - tag: component\r\n    value: memory\r\n  - tag: component\r\n    value: storage\r\n- name: Free swap space in %\r\n  key: system.swap.pfree\r\n  interval: '0'\r\n  type: dependent\r\n  master_item_key: perf_counter_en[\"\\Paging file(_Total)\\% Usage\"]\r\n  units: '%'\r\n  description: The free space of the swap volume/file expressed in %.\r\n  history: 31d\r\n  tags:\r\n  - tag: component\r\n    value: memory\r\n  - tag: component\r\n    value: storage\r\n- name: Total swap space\r\n  key: system.swap.size[,total]\r\n  interval: 1m\r\n  value_type: unsigned\r\n  units: B\r\n  description: The total space of the swap volume/file expressed in bytes.\r\n  history: 31d\r\n  tags:\r\n  - tag: component\r\n    value: memory\r\n  - tag: component\r\n    value: storage\r\n- name: System description\r\n  key: system.uname\r\n  interval: 15m\r\n  value_type: char\r\n  description: System description of the host.\r\n  history: 31d\r\n  trends: '0'\r\n  tags:\r\n  - tag: component\r\n    value: system\r\n"]
[30.044417, "o", "- name: Uptime\r\n  key: system.uptime\r\n  interval: 30s\r\n  value_type: unsigned\r\n  units: uptime\r\n  description: 'The system uptime expressed in the following format: \"N days, hh:mm:ss\".'\r\n  history: 31d\r\n  trends: '0'\r\n  tags:\r\n  - tag: component\r\n    value: system\r\n- name: Get filesystems\r\n  key: vfs.fs.get\r\n  interval: 1m\r\n  value_type: text\r\n  description: The `vfs.fs.get` key acquires raw information set about the filesystems.\r\n    Later to be extracted by preprocessing in dependent items.\r\n  history: '0'\r\n  trends: '0'\r\n  tags:\r\n  - tag: component\r\n    value: raw\r\n- name: Total memory\r\n  key: vm.memory.size[total]\r\n  interval: 1m\r\n  value_type: unsigned\r\n  units: B\r\n  description: Total memory expressed in bytes.\r\n  history: 31d\r\n  tags:\r\n  - tag: component\r\n    value: memory\r\n- name: Used memory\r\n  key: vm.memory.size[used]\r\n  interval: 1m\r\n  value_type: unsigned\r\n  units: B\r\n  description: Used memory in bytes.\r\n  history: 31d\r\n  tags:\r\n  - tag: component\r\n    value: memory\r\n- name: Memory utilization\r\n  key: vm.memory.util\r\n  interval: 1m\r\n  type: calculated\r\n  params: last(//vm.memory.size[used]) / last(//vm.memory.size[total]) * 100\r\n  units: '%'\r\n  description: Memory utilization in %.\r\n  history: 31d\r\n  tags:\r\n  - tag: component\r\n    value: memory\r\n- name: Number of cores\r\n  key: wmi.get[root/cimv2,\"Select NumberOfLogicalProcessors from Win32_ComputerSystem\"]\r\n  interval: 1m\r\n  value_type: unsigned\r\n  description: The number of logical processors available on the computer.\r\n  history: 31d\r\n  tags:\r\n  - tag: component\r\n    value: cpu\r\n- name: 'Windows: Network interfaces WMI get'\r\n  key: wmi.getall[root\\cimv2,\"select Name,Description,NetConnectionID,Speed,AdapterTypeId,NetConnectionStatus,GUID\r\n    from win32_networkadapter where PhysicalAdapter=True and NetConnectionStatus>0\"]\r\n  interval: 1m\r\n  value_type: text\r\n  description: Raw data of `win32_networkadapter.`\r\n  history: '0'\r\n  trends: '0'\r\n  tags:\r\n  - tag: component\r\n    value: raw\r\n- name: Zabbix agent availability\r\n  key: zabbix[host,agent,available]\r\n  interval: 1m\r\n  type: zabbix_internal\r\n  value_type: unsigned\r\n  description: Used for monitoring the availability status of the agent.\r\n  history: 31d\r\n  tags:\r\n  - tag: component\r\n    value: system\r\ntriggers:\r\n- name: 'Windows: Number of free system page table entries is too low'\r\n  expression: max(/Windows by Zabbix agent/perf_counter_en[\"\\Memory\\Free System Page\r\n    Table Entries\"],5m)<5000\r\n  severity: warning\r\n  description: '`Memory\\Free System Page Table Entries` has been less than `{$MEM.PAGE_TABLE_CRIT.MIN}`\r\n    for 5 minutes. If the number is less than 5,000, there may be a memory leak.'\r\n  tags:\r\n  - tag: scope\r\n    value: capacity\r\n- name: 'Windows: The Memory Pages/sec is too high'\r\n  expression: min(/Windows by Zabbix agent/perf_counter_en[\"\\Memory\\Pages/sec\"],5m)>1000\r\n  severity: warning\r\n  description: The Memory Pages/sec in the last 5 minutes exceeds `{$MEM.PAGE_SEC.CRIT.MAX}`.\r\n    If the value is greater than 1,000, as a result of excessive paging, there may\r\n    be a memory leak.\r\n  tags:\r\n  - tag: scope\r\n    value: capacity\r\n- name: 'Windows: CPU interrupt time is too high'\r\n  expression: min(/Windows by Zabbix agent/perf_counter_en[\"\\Processor Information(_total)\\%\r\n    Interrupt Time\"],5m)>50\r\n  severity: warning\r\n  description: The CPU Interrupt Time in the last 5 minutes exceeds `{$CPU.INTERRUPT.CRIT.MAX}`%.\r\n  tags:\r\n  - tag: scope\r\n    value: performance\r\n- name: 'Windows: CPU privileged time is too high'\r\n  expression: min(/Windows by Zabbix agent/perf_counter_en[\"\\Processor Information(_total)\\%\r\n    Privileged Time\"],5m)>30\r\n  severity: warning\r\n  description: The CPU privileged time in the last 5 minutes exceeds {$CPU.PRIV.CRIT.MAX}%.\r\n  tags:\r\n  - tag: scope\r\n    value: performance\r\n- name: 'Windows: CPU queue length is too high'\r\n  expression: min(/Windows by Zabbix agent/perf_counter_en[\"\\System\\Processor Queue\r\n    Length\"],5m) - last(/Windows by Zabbix agent/wmi.get[root/cimv2,\"Select NumberOfLogicalProcessors\r\n    from Win32_ComputerSystem\"]) * 2 > 3\r\n  severity: warning\r\n  description: The CPU Queue Length in the last 5 minutes exceeds `{$CPU.QUEUE.CRIT.MAX}`.\r\n    According to actual observations, PQL should not exceed the number of cores *\r\n    2. To fine-tune the conditions, use the macro `{$CPU.QUEUE.CRIT.MAX }`.\r\n  tags:\r\n  - tag: scope\r\n    value: performance\r\n- name: 'Windows: High CPU utilization'\r\n  expression: min(/Windows by Zabbix agent/system.cpu.util,5m)>90\r\n  severity: warning\r\n  description: CPU utilization is too high. The system might be slow to respond.\r\n  tags:\r\n  - tag: scope\r\n    value: performance\r\n- name: 'Windows: System name has changed'\r\n  expression: change(/Windows by Zabbix agent/system.hostname) and length(last(/Windows\r\n    by Zabbix agent/system.hostname))>0\r\n  severity: information\r\n  description: The name of the system has changed. Acknowledge to close the problem\r\n    manually.\r\n  tags:\r\n  - tag: scope\r\n    value: notice\r\n- name: 'Windows: System time is out of sync'\r\n  expression: fuzzytime(/Windows by Zabbix agent/system.localtime,60s)=0\r\n  severity: warning\r\n  recovery_expression: fuzzytime(/Windows by Zabbix agent/system.localtime,10s)=1\r\n  description: The host's system time is different from Zabbix server time.\r\n  tags:\r\n  - tag: scope\r\n    value: notice\r\n- name: 'Windows: Operating system description has changed'\r\n  expression: change(/Windows by Zabbix agent/system.sw.os) and length(last(/Windows\r\n    by Zabbix agent/system.sw.os))>0\r\n  severity: information\r\n  description: The description of the operating system has changed. Possible reasons\r\n    are that the system has been updated or replaced. Acknowledge to close the problem\r\n    manually.\r\n  tags:\r\n  - tag: scope\r\n    value: notice\r\n- name: 'Windows: High swap space usage'\r\n  expression: max(/Windows by Zabbix agent/system.swap.pfree,5m)<20 and last(/Windows\r\n    by Zabbix agent/system.swap.size[,total])>0\r\n  severity: warning\r\n  description: This trigger is ignored, if there is no swap configured\r\n  tags:\r\n  - tag: scope\r\n    value: performance\r\n- name: 'Windows: Host has been restarted'\r\n  expression: last(/Windows by Zabbix agent/system.uptime)<10m\r\n  severity: warning\r\n  description: The device uptime is less than 10 minutes.\r\n  tags:\r\n  - tag: scope\r\n    value: notice\r\n- name: 'Windows: High memory utilization'\r\n  expression: min(/Windows by Zabbix agent/vm.memory.util,5m)>90\r\n  severity: average\r\n  description: The system is running out of free memory.\r\n  tags:\r\n  - tag: scope\r\n    value: capacity\r\n  - tag: scope\r\n    value: performance\r\n- name: 'Windows: Zabbix agent is not available'\r\n  expression: max(/Windows by Zabbix agent/zabbix[host,agent,available],3m)=0\r\n  severity: average\r\n  description: For passive agents only, host availability is used with `{$AGENT.TIMEOUT}`\r\n    as a time threshold.\r\n  tags:\r\n  - tag: scope\r\n    value: availability\r\ndiscovery_rules:\r\n- name: Network interfaces discovery\r\n  key: net.if.discovery\r\n  interval: '0'\r\n  type: dependent\r\n  master_item_key: wmi.getall[root\\cimv2,\"select Name,Description,NetConnectionID,Speed,AdapterTypeId,NetConnectionStatus,GUID\r\n    from win32_networkadapter where PhysicalAdapter=True and NetConnectionStatus>0\"]\r\n  filter:\r\n  - macro: '{#IFALIAS}'\r\n    value: '{$NET.IF.IFALIAS.MATCHES}'\r\n  - macro: '{#IFALIAS}'\r\n    value: '{$NET.IF.IFALIAS.NOT_MATCHES}'\r\n  - macro: '{#IFDESCR}'\r\n    value: '{$NET.IF.IFDESCR.MATCHES}'\r\n  - macro: '{#IFDESCR}'\r\n    value: '{$NET.IF.IFDESCR.NOT_MATCHES}'\r\n  - macro: '{#IFNAME}'\r\n    value: '{$NET.IF.IFNAME.MATCHES}'\r\n  - macro: '{#IFNAME}'\r\n    value: '{$NET.IF.IFNAME.NOT_MATCHES}'\r\n  item_prototypes:\r\n  - name: 'Interface {#IFNAME}({#IFALIAS}): Inbound packets discarded'\r\n    key: net.if.in[\"{#IFGUID}\",dropped]\r\n    interval: 3m\r\n    value_type: unsigned\r\n  - name: 'Interface {#IFNAME}({#IFALIAS}): Inbound packets with errors'\r\n    key: net.if.in[\"{#IFGUID}\",errors]\r\n    interval: 3m\r\n    value_type: unsigned\r\n  - name: 'Interface {#IFNAME}({#IFALIAS}): Bits received'\r\n    key: net.if.in[\"{#IFGUID}\"]\r\n    interval: 3m\r\n    value_type: unsigned\r\n    units: bps\r\n  - name: 'Interface {#IFNAME}({#IFALIAS}): Outbound packets discarded'\r\n    key: net.if.out[\"{#IFGUID}\",dropped]\r\n    interval: 3m\r\n    value_type: unsigned\r\n  - name: 'Interface {#IFNAME}({#IFALIAS}): Outbound packets with errors'\r\n    key: net.if.out[\"{#IFGUID}\",errors]\r\n    interval: 3m\r\n    value_type: unsigned\r\n  - name: 'Interface {#IFNAME}({#IFALIAS}): Bits sent'\r\n    key: net.if.out[\"{#IFGUID}\"]\r\n    interval: 3m\r\n    value_type: unsigned\r\n    units: bps\r\n  - name: 'Interface {#IFNAME}({#IFALIAS}): Speed'\r\n    key: net.if.speed[\"{#IFGUID}\"]\r\n    interval: '0'\r\n    type: dependent\r\n    value_type: unsigned\r\n    units: bps\r\n  - name: 'Interface {#IFNAME}({#IFALIAS}): Operational status'\r\n    key: net.if.status[\"{#IFGUID}\"]\r\n    interval: '0'\r\n    type: dependent\r\n    value_type: unsigned\r\n  - name: 'Interface {#IFNAME}({#IFALIAS}): Interface type'\r\n    key: net.if.type[\"{#IFGUID}\"]\r\n    interval: '0'\r\n    type: dependent\r\n    value_type: unsigned\r\n  trigger_prototypes:\r\n  - name: 'Windows: Interface {#IFNAME}({#IFALIAS}): High error rate'\r\n    expression: \"min(/Windows by Zabbix agent/net.if.in[\\\"{#IFGUID}\\\",errors],5m)>2\\r\\\r\n      \\nor min(/Windows by Zabbix agent/net.if.out[\\\"{#IFGUID}\\\",errors],5m)>2\"\r\n    severity: warning\r\n    recovery_expression: \"max(/Windows by Zabbix agent/net.if.in[\\\"{#IFGUID}\\\",errors],5m)<2*0.8\\r\\\r\n      \\nand max(/Windows by Zabbix agent/net.if.out[\\\"{#IFGUID}\\\",errors],5m)<2*0.8\"\r\n    allow_manual_close: true\r\n  - name: 'Windows: Interface {#IFNAME}({#IFALIAS}): High bandwidth usage'\r\n    expression: \"(avg(/Windows by Zabbix agent/net.if.in[\\\"{#IFGUID}\\\"],15m)>(90/100)*last(/Windows\\\r\n      \\ by Zabbix agent/net.if.speed[\\\"{#IFGUID}\\\"]) or\\r\\navg(/Windows by Zabbix\\\r\n      \\ agent/net.if.out[\\\"{#IFGUID}\\\"],15m)>(90/100)*last(/Windows by Zabbix agent/net.if.speed[\\\"\\\r\n      {#IFGUID}\\\"])) and\\r\\nlast(/Windows by Zabbix agent/net.if.speed[\\\"{#IFGUID}\\\"\\\r\n      ])>0\"\r\n    severity: warning\r\n    recovery_expression: \"avg(/Windows by Zabbix agent/net.if.in[\\\"{#IFGUID}\\\"],15m)<((90-3)/100)*last(/Windows\\\r\n      \\ by Zabbix agent/net.if.speed[\\\"{#IFGUID}\\\"]) and\\r\\navg(/Windows by Zabbix\\\r\n      \\ agent/net.if.out[\\\"{#IFGUID}\\\"],15m)<((90-3)/100)*last(/Windows by Zabbix\\\r\n      \\ agent/net.if.speed[\\\"{#IFGUID}\\\"])\"\r\n    allow_manual_close: true\r\n  - name: 'Windows: Interface {#IFNAME}({#IFALIAS}): Ethernet has changed to lower\r\n      speed than it was before'\r\n    expression: \"change(/Windows by Zabbix agent/net.if.speed[\\\"{#IFGUID}\\\"])<0 and\\r\\\r\n      \\nlast(/Windows by Zabbix agent/net.if.speed[\\\"{#IFGUID}\\\"])>0 and\\r\\nlast(/Windows\\\r\n      \\ by Zabbix agent/net.if.status[\\\"{#IFGUID}\\\"])=2\"\r\n    severity: information\r\n    allow_manual_close: true\r\n  - name: 'Windows: Interface {#IFNAME}({#IFALIAS}): Link down'\r\n    expression: 1=1 and last(/Windows by Zabbix agent/net.if.status[\"{#IFGUID}\"])<>2\r\n      and (last(/Windows by Zabbix agent/net.if.status[\"{#IFGUID}\"],#1)<>last(/Windows\r\n      by Zabbix agent/net.if.status[\"{#IFGUID}\"],#2))\r\n    severity: average\r\n    recovery_expression: last(/Windows by Zabbix agent/net.if.status[\"{#IFGUID}\"])=2\r\n      or 1=0\r\n    allow_manual_close: true\r\n- name: Physical disks discovery\r\n  key: perf_instance_en.discovery[PhysicalDisk]\r\n  interval: 1h\r\n  filter:\r\n  - macro: '{#DEVNAME}'\r\n    value: '{$VFS.DEV.DEVNAME.MATCHES}'\r\n  - macro: '{#DEVNAME}'\r\n    value: '{$VFS.DEV.DEVNAME.NOT_MATCHES}'\r\n  item_prototypes:\r\n  - name: '{#DEVNAME}: Disk utilization by idle time'\r\n    key: perf_counter_en[\"\\PhysicalDisk({#DEVNAME})\\% Idle Time\",60]\r\n    interval: 1m\r\n    units: '%'\r\n  - name: '{#DEVNAME}: Average disk read queue length'\r\n    key: perf_counter_en[\"\\PhysicalDisk({#DEVNAME})\\Avg. Disk Read Queue Length\",60]\r\n    interval: 1m\r\n  - name: '{#DEVNAME}: Disk read request avg waiting time'\r\n    key: perf_counter_en[\"\\PhysicalDisk({#DEVNAME})\\Avg. Disk sec/Read\",60]\r\n    interval: 1m\r\n    units: s\r\n  - name: '{#DEVNAME}: Disk write request avg waiting time'\r\n    key: perf_counter_en[\"\\PhysicalDisk({#DEVNAME})\\Avg. Disk sec/Write\",60]\r\n    interval: 1m\r\n    units: s\r\n  - name: '{#DEVNAME}: Average disk write queue length'\r\n    key: perf_counter_en[\"\\PhysicalDisk({#DEVNAME})\\Avg. Disk Write Queue Length\",60]\r\n    interval: 1m\r\n  - name: '{#DEVNAME}: Disk average queue size (avgqu-sz)'\r\n    key: perf_counter_en[\"\\PhysicalDisk({#DEVNAME})\\Current Disk Queue Length\",60]\r\n    interval: 1m\r\n  - name: '{#DEVNAME}: Disk read rate'\r\n    key: perf_counter_en[\"\\PhysicalDisk({#DEVNAME})\\Disk Reads/sec\",60]\r\n    interval: 1m\r\n    units: '!r/s'\r\n  - name: '{#DEVNAME}: Disk write rate'\r\n    key: perf_counter_en[\"\\PhysicalDisk({#DEVNAME})\\Disk Writes/sec\",60]\r\n    interval: 1m\r\n    units: '!w/s'\r\n  trigger_prototypes:\r\n  - name: 'Windows: {#DEVNAME}: Disk is overloaded'\r\n    expression: min(/Windows by Zabbix agent/perf_counter_en[\"\\PhysicalDisk({#DEVNAME})\\%\r\n      Idle Time\",60],15m)>95\r\n    severity: warning\r\n    allow_manual_close: true\r\n  - name: 'Windows: {#DEVNAME}: Disk read request responses are too high'\r\n    expression: min(/Windows by Zabbix agent/perf_counter_en[\"\\PhysicalDisk({#DEVNAME})\\Avg.\r\n      Disk sec/Read\",60],15m) > 0.02\r\n    severity: warning\r\n    allow_manual_close: true\r\n  - name: 'Windows: {#DEVNAME}: Disk write request responses are too high'\r\n    expression: min(/Windows by Zabbix agent/perf_counter_en[\"\\PhysicalDisk({#DEVNAME})\\Avg.\r\n      Disk sec/Write\",60],15m) > 0.02\r\n    severity: warning\r\n    allow_manual_close: true\r\n- name: Windows services discovery\r\n  key: service.discovery\r\n  interval: 1h\r\n  filter:\r\n  - macro: '{#SERVICE.NAME}'\r\n    value: '{$SERVICE.NAME.MATCHES}'\r\n  - macro: '{#SERVICE.NAME}'\r\n    value: '{$SERVICE.NAME.NOT_MATCHES}'\r\n  - macro: '{#SERVICE.STARTUPNAME}'\r\n    value: '{$SERVICE.STARTUPNAME.MATCHES}'\r\n  - macro: '{#SERVICE.STARTUPNAME}'\r\n    value: '{$SERVICE.STARTUPNAME.NOT_MATCHES}'\r\n  item_prototypes:\r\n  - name: State of service \"{#SERVICE.NAME}\" ({#SERVICE.DISPLAYNAME})\r\n    key: service.info[\"{#SERVICE.NAME}\",state]\r\n    interval: 1m\r\n    value_type: unsigned\r\n  trigger_prototypes:\r\n  - name: 'Windows: \"{#SERVICE.NAME}\" ({#SERVICE.DISPLAYNAME}) is not running'\r\n    expression: min(/Windows by Zabbix agent/service.info[\"{#SERVICE.NAME}\",state],#3)<>0\r\n    severity: average\r\n- name: Mounted filesystem discovery\r\n  key: vfs.fs.dependent.discovery\r\n  interval: '0'\r\n  type: dependent\r\n  master_item_key: vfs.fs.get\r\n  filter:\r\n  - macro: '{#FSDRIVETYPE}'\r\n    value: '{$VFS.FS.FSDRIVETYPE.MATCHES}'\r\n  - macro: '{#FSDRIVETYPE}'\r\n    value: '{$VFS.FS.FSDRIVETYPE.NOT_MATCHES}'\r\n  - macro: '{#FSNAME}'\r\n    value: '{$VFS.FS.FSNAME.MATCHES}'\r\n  - macro: '{#FSNAME}'\r\n    value: '{$VFS.FS.FSNAME.NOT_MATCHES}'\r\n  - macro: '{#FSTYPE}'\r\n    value: '{$VFS.FS.FSTYPE.MATCHES}'\r\n  - macro: '{#FSTYPE}'\r\n    value: '{$VFS.FS.FSTYPE.NOT_MATCHES}'\r\n  item_prototypes:\r\n  - name: 'FS [{#FSLABEL}({#FSNAME})]: Get data'\r\n    key: vfs.fs.dependent[{#FSNAME},data]\r\n    interval: '0'\r\n    type: dependent\r\n    value_type: text\r\n  - name: 'FS [{#FSLABEL}({#FSNAME})]: Space: Available'\r\n    key: vfs.fs.dependent.size[{#FSNAME},free]\r\n    interval: '0'\r\n    type: dependent\r\n    master_item_key: vfs.fs.dependent[{#FSNAME},data]\r\n    value_type: unsigned\r\n    units: B\r\n  - name: 'FS [{#FSLABEL}({#FSNAME})]: Space: Used, in %'\r\n    key: vfs.fs.dependent.size[{#FSNAME},pused]\r\n    interval: '0'\r\n    type: dependent\r\n    master_item_key: vfs.fs.dependent[{#FSNAME},data]\r\n    units: '%'\r\n  - name: 'FS [{#FSLABEL}({#FSNAME})]: Space: Total'\r\n    key: vfs.fs.dependent.size[{#FSNAME},total]\r\n    interval: '0'\r\n    type: dependent\r\n    master_item_key: vfs.fs.dependent[{#FSNAME},data]\r\n    value_type: unsigned\r\n    units: B\r\n  - name: 'FS [{#FSLABEL}({#FSNAME})]: Space: Used'\r\n    key: vfs.fs.dependent.size[{#FSNAME},used]\r\n    interval: '0'\r\n    type: dependent\r\n    master_item_key: vfs.fs.dependent[{#FSNAME},data]\r\n    value_type: unsigned\r\n    units: B\r\n  trigger_prototypes:\r\n  - name: 'Windows: FS [{#FSLABEL}({#FSNAME})]: Space is critically low'\r\n    expression: min(/Windows by Zabbix agent/vfs.fs.dependent.size[{#FSNAME},pused],5m)>90\r\n    severity: average\r\n    allow_manual_close: true\r\n  - name: 'Windows: FS [{#FSLABEL}({#FSNAME})]: Space is low'\r\n    expression: min(/Windows by Zabbix agent/vfs.fs.dependent.size[{#FSNAME},pused],5m)>80\r\n    severity: warning\r\n    allow_manual_close: true\r\n"]
[32.363076, "o", "\r\n\u001b[1;36m8. Saved plans for CI/CD gating\u001b[0m\r\n"]
[32.966161, "o", "\u001b[1;32m$ zbx plan configs/checks/ --output /tmp/zbx.plan.json\u001b[0m\r\n"]
[34.619773, "o", "\u001b[32mв•­в”Ђ\u001b[0m\u001b[32m \u001b[0m\u001b[1;32m+ \u001b[0m\u001b[1;32mtemplate: \u001b[0m\u001b[1;32mapache-httpd\u001b[0m\u001b[32m \u001b[0m\u001b[32mв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\u001b[0m\u001b[32mв”Ђв•®\u001b[0m\r\n\u001b[32mв”‚\u001b[0m \u001b[1;32m  + \u001b[0m\u001b[32mitem: \u001b[0m\u001b[1;32mApache ping\u001b[0m  [dim](apache.stat[ping])[/dim]                \u001b[32mв”‚\u001b[0m\r\n\u001b[32mв”‚\u001b[0m \u001b[1;32m  + \u001b[0m\u001b[32mitem: \u001b[0m\u001b[1;32mTotal accesses\u001b[0m  [dim](apache.stat[total_accesses])[/dim]   \u001b[32mв”‚\u001b[0m\r\n\u001b[32mв”‚\u001b[0m \u001b[1;32m  + \u001b[0m\u001b[32mitem: \u001b[0m\u001b[1;32mTotal kbytes\u001b[0m  [dim](apache.stat[total_kbytes])[/dim]       \u001b[32mв”‚\u001b[0m\r\n\u001b[32mв”‚\u001b[0m \u001b[1;32m  + \u001b[0m\u001b[32mitem: \u001b[0m\u001b[1;32mRequests per second\u001b[0m  [dim](apache.stat[req_per_sec])[/dim] \u001b[32mв”‚\u001b[0m\r\n\u001b[32mв”‚\u001b[0m \u001b[1;32m  + \u001b[0m\u001b[32mitem: \u001b[0m\u001b[1;32mBytes per second\u001b[0m  [dim](apache.stat[bytes_per_sec])[/dim]  \u001b[32mв”‚\u001b[0m\r\n\u001b[32mв”‚\u001b[0m \u001b[1;32m  + \u001b[0m\u001b[32mitem: \u001b[0m\u001b[1;32mBusy workers\u001b[0m  [dim](apache.stat[busy_workers])[/dim]       \u001b[32mв”‚\u001b[0m\r\n\u001b[32mв”‚\u001b[0m \u001b[1;32m  + \u001b[0m\u001b[32mitem: \u001b[0m\u001b[1;32mIdle workers\u001b[0m  [dim](apache.stat[idle_workers])[/dim]       \u001b[32mв”‚\u001b[0m\r\n\u001b[32mв”‚\u001b[0m \u001b[1;32m  + \u001b[0m\u001b[32mitem: \u001b[0m\u001b[1;32mUptime (seconds)\u001b[0m  [dim](apache.stat[uptime])[/dim]         \u001b[32mв”‚\u001b[0m\r\n\u001b[32mв”‚\u001b[0m \u001b[1;32m  + \u001b[0m\u001b[32mtrigger: \u001b[0m\u001b[1;32mApache is unreachable\u001b[0m                                   \u001b[32mв”‚\u001b[0m\r\n\u001b[32mв”‚\u001b[0m \u001b[1;32m  + \u001b[0m\u001b[32mtrigger: \u001b[0m\u001b[1;32mNo idle workers (saturation)\u001b[0m                            \u001b[32mв”‚\u001b[0m\r\n\u001b[32mв•°в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв•Ї\u001b[0m\r\n"]
