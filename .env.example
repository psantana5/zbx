# zbx environment configuration
# Copy this file to .env and fill in your values.
# Never commit .env to version control.

# Required — Zabbix server base URL (no trailing slash)
ZBX_URL=http://zabbix.example.com

# Required — Zabbix user credentials
ZBX_USER=Admin
ZBX_PASSWORD=zabbix

# Optional — disable SSL certificate verification (default: true)
# Set to false only in development/staging environments
ZBX_VERIFY_SSL=true

# Optional — API request timeout in seconds (default: 30)
ZBX_TIMEOUT=30
